<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Selenium Framework Suite" parallel="methods" thread-count="3">
    <listeners>
        <listener class-name="framework.utils.RetryListener"/>
    </listeners>
    <test name="All Tests">
        <packages>
            <package name="tests"/>
        </packages>
    </test>
</suite>
